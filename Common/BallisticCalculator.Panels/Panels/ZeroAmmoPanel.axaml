<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:panels="using:BallisticCalculator.Panels.Panels"
             mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="300"
             x:Class="BallisticCalculator.Panels.Panels.ZeroAmmoPanel">

  <StackPanel Spacing="4">
    <StackPanel Orientation="Horizontal" Spacing="10">
      <CheckBox x:Name="EnableCheckBox" x:FieldModifier="internal"
                Content="Other ammunition for zero"
                FontSize="{DynamicResource AppFontSize}"/>
      <Button x:Name="LoadButton" x:FieldModifier="internal"
              Content="Load..."
              IsEnabled="False"
              FontSize="{DynamicResource AppFontSize}"/>
    </StackPanel>

    <panels:AmmoPanel x:Name="AmmoSubPanel" x:FieldModifier="internal"
                      IsEnabled="False"
                      FontSize="{DynamicResource AppFontSize}"/>
  </StackPanel>
</UserControl>
