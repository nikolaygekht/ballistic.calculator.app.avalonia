<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:panels="using:BallisticCalculator.Panels.Panels"
        x:Class="BallisticCalculator.Views.Dialogs.ShotParametersDialog"
        Title="Shot Parameters"
        Width="550" Height="500"
        MinWidth="450" MinHeight="400"
        FontSize="{DynamicResource AppFontSize}"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Center" Spacing="10" Margin="0,10,0,10">
            <Button Content="OK" Click="OnOK" Width="80" FontSize="{DynamicResource AppFontSize}" />
            <Button Content="Cancel" Click="OnCancel" Width="80" FontSize="{DynamicResource AppFontSize}" />
        </StackPanel>

        <panels:ShotDataPanel x:Name="ShotDataPanel" Margin="5"
                              FontSize="{DynamicResource AppFontSize}" />
    </DockPanel>
</Window>
