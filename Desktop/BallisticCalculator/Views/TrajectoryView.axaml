<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:BallisticCalculator.Controls.Controls"
             x:Class="BallisticCalculator.Views.TrajectoryView"
             FontSize="{DynamicResource AppFontSize}">

    <TabControl x:Name="Tabs">
        <TabItem Header="Table">
            <controls:TrajectoryTableControl x:Name="TableControl" />
        </TabItem>
        <TabItem Header="Chart">
            <controls:TrajectoryChartControl x:Name="ChartControl" />
        </TabItem>
        <TabItem Header="Reticle">
            <TextBlock Text="Reticle view — not yet implemented"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="Gray" />
        </TabItem>
    </TabControl>
</UserControl>
